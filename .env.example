# DentalFlow Agent - Environment Variables
# Copy this file to .env and fill in your values
# cp .env.example .env

# ── EHR API ────────────────────────────────────────────────────────────────────
# URL where the DentalFlow EHR API is running
# Local dev: http://localhost:3001
# Docker:    http://ehr-api:3001
EHR_BASE_URL=http://localhost:3001

# ── Agent API (Flask) ──────────────────────────────────────────────────────────
# Port for the agent HTTP API that Maestro calls
AGENT_API_PORT=8080

# Set to true for verbose Flask dev output (never use in production)
FLASK_DEBUG=false

# ── Agent Behavior ─────────────────────────────────────────────────────────────
# Seconds between polls in continuous loop mode
POLL_INTERVAL=30
